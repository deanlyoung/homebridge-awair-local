{
  "pluginAlias": "AwairLocal",
  "pluginType": "platform",
  "singular": true,
  "headerDisplay": "Awair Local dynamic platform. Manually configured devices and mDNS-discovered devices use Awair's local endpoints only.",
  "schema": {
    "type": "object",
    "properties": {
      "name": { "title": "Platform Name", "type": "string", "default": "Awair Local" },
      "discovery": { "title": "Discover Awairs with mDNS", "type": "boolean", "default": true, "description": "Browses mDNS/DNS-SD services and verifies candidates with /settings/config/data." },
      "mdnsServiceTypes": { "title": "mDNS service types", "type": "array", "items": { "type": "string" }, "default": ["_http._tcp.local", "_awair._tcp.local"], "description": "Optional service types to browse. Awair has not published a universal DNS-SD type." },
      "discoveryHostnames": { "title": "Known mDNS hostnames", "type": "array", "items": { "type": "string" }, "description": "Optional hostnames such as awair-elem-56cd78.local to verify at startup." },
      "devices": { "title": "Awair devices", "type": "array", "items": { "$ref": "#/definitions/device" }, "default": [] }
    },
    "definitions": {
      "device": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "title": "Accessory name" },
          "ip": { "type": "string", "title": "IP address or mDNS hostname" },
          "host": { "type": "string", "title": "Endpoint host" },
          "url": { "type": "string", "title": "Air-data URL override" },
          "configUrl": { "type": "string", "title": "Settings URL override" },
          "model": { "type": "string", "title": "Model" },
          "devType": { "type": "string", "title": "Legacy device type" },
          "manufacturer": { "type": "string", "title": "Manufacturer", "default": "Awair" },
          "serial": { "type": "string", "title": "Serial number" },
          "version": { "type": "string", "title": "Firmware version" },
          "carbonDioxideThreshold": { "type": "number", "title": "CO2 alert threshold (ppm)", "default": 0 },
          "carbonDioxideThresholdOff": { "type": "number", "title": "CO2 alert clear threshold (ppm)" },
          "voc_mixture_mw": { "type": "number", "title": "VOC reference gas molecular weight", "default": 72.6657827301974 },
          "air_quality_method": { "type": "string", "enum": ["awair-score", "awair-aqi", "awair-pm25"], "default": "awair-score", "title": "Air-quality calculation" },
          "polling_interval": { "type": "integer", "minimum": 1, "title": "Polling interval (seconds)", "default": 10 },
          "limit": { "type": "integer", "minimum": 1, "title": "Legacy data point limit", "default": 1, "description": "Retained for configuration compatibility; /air-data/latest returns one sample." },
          "logging": { "type": "boolean", "title": "Verbose logging", "default": false },
          "logging_level": { "type": "integer", "title": "Legacy logging level", "default": 0 },
          "requestTimeout": { "type": "integer", "minimum": 1000, "title": "Request timeout (ms)", "default": 5000 }
        },
        "anyOf": [{ "required": ["ip"] }, { "required": ["host"] }]
      }
    }
  },
  "layout": ["name", "discovery", "mdnsServiceTypes", "discoveryHostnames", "devices"]
}
